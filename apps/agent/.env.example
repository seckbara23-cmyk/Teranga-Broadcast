# Teranga Broadcast Agent — local service environment (EXAMPLE)
# Copy to .env and fill in. This file stays on the production workstation; the
# OBS password and service-role key must never be committed or synced.

# --- Platform (Supabase / Kernel AgentRegistry) ---
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="agent-service-role-key"   # trusted local service
TERANGA_ORG_ID="your-organization-uuid"

# --- Agent identity ---
AGENT_KEY=""                # stable per-workstation id (defaults to hostname)
AGENT_NAME=""               # display name (defaults to "Agent <hostname>")

# --- OBS WebSocket v5 (read-only this phase) ---
OBS_WEBSOCKET_URL="ws://127.0.0.1:4455"
OBS_WEBSOCKET_PASSWORD="your-obs-websocket-password"

# --- Local media storage (folders only — no media written this phase) ---
MEDIA_ROOT="./media"
