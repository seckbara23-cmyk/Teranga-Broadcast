# Teranga Agent — local edge service environment (EXAMPLE)
# Copy to .env and fill in. This file stays on the production machine; the OBS
# password and service token must never be committed or synced to the cloud.

# --- OBS WebSocket v5 (local) ---
OBS_WEBSOCKET_URL="ws://127.0.0.1:4455"
OBS_WEBSOCKET_PASSWORD="your-obs-websocket-password"

# --- Supabase (Cloud for MVP; self-hosted URL for on-prem) ---
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="agent-scoped-service-key"

# --- Local media paths ---
RECORDING_DIR="./recordings"
REPLAY_BUFFER_DIR="./buffer"
EXPORT_DIR="./exports"

# --- Which match this agent instance is bound to (set at session start) ---
TERANGA_MATCH_ID=""
