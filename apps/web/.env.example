# Teranga Broadcast — web app environment (EXAMPLE)
# Copy to .env.local and fill in. Nothing here is hardcoded in code: pointing at a
# self-hosted Supabase instance is purely a change of these values.

# --- Supabase (Cloud for MVP; self-hosted URL for on-prem) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-publishable-key"

# Server-only (never expose to the browser):
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Overlay signing (per-match read-only tokens for OBS browser sources) ---
OVERLAY_TOKEN_SECRET="generate-a-long-random-secret"
