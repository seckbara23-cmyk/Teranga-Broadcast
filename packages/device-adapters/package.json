    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@teranga/agent-core": "workspace:*",
    "obs-websocket-js": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "typescript": "^5.7.0"
  }
}
