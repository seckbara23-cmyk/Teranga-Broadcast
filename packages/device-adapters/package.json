{
  "name": "@teranga/device-adapters",
  "version": "0.0.0",
  "private": true,
  "description": "Device adapters for the Teranga Broadcast Agent. Read-only OBS adapter implemented; vMix/ATEM/NDI/FFmpeg/HyperDeck/EVS are interface stubs.",
  "type": "module",
  "main": "./src/index.ts",
